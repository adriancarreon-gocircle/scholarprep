# ─── ScholarPrep Environment Variables ────────────────────────────────────────
# Copy this file to .env.local and fill in your real values

# ── Supabase (for login / accounts / data storage) ──────────────────────────
# Get these from: https://supabase.com → your project → Settings → API
REACT_APP_SUPABASE_URL=https://your-project-ref.supabase.co
REACT_APP_SUPABASE_ANON_KEY=your-anon-public-key-here

# ── Stripe (for payments) ────────────────────────────────────────────────────
# Get this from: https://dashboard.stripe.com → Developers → API Keys
REACT_APP_STRIPE_PUBLISHABLE_KEY=pk_live_your-stripe-publishable-key

# ── Notes ────────────────────────────────────────────────────────────────────
# The Claude API key is handled server-side via the claude.ai artifact system
# Never commit .env.local to git
